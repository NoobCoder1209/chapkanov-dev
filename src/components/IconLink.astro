---
import { Icon } from "astro-icon/components";

/**
 * IconLink — anchor with a Lucide icon and an accessible tooltip.
 * Visible label (aria-label + CSS tooltip on hover/focus). Used in Footer + /contact.
 *
 * For external links, defaults to target=_blank + rel="noopener noreferrer".
 */
interface Props {
  href: string;
  icon: string; // lucide icon name (e.g. "github", "mail")
  label: string;
  external?: boolean;
  class?: string;
}

const { href, icon, label, external, class: className = "" } = Astro.props;
const isExternal = external ?? /^https?:/.test(href);
const targetAttrs = isExternal ? { target: "_blank", rel: "noopener noreferrer" } : {};
---

<a
  href={href}
  aria-label={label}
  data-tooltip={label}
  class:list={[
    "icon-link inline-flex h-10 w-10 items-center justify-center rounded-md text-muted transition-colors duration-fast ease-out hover:bg-subtle hover:text-fg",
    className,
  ]}
  {...targetAttrs}
>
  <Icon name={`lucide:${icon}`} class="h-5 w-5" aria-hidden="true" />
</a>

<style>
  .icon-link {
    position: relative;
  }
  .icon-link[data-tooltip]::after {
    content: attr(data-tooltip);
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%) translateY(-2px);
    padding: 4px 8px;
    font-size: var(--fs-xs);
    line-height: 1;
    white-space: nowrap;
    background: var(--color-fg);
    color: var(--color-bg);
    border-radius: var(--radius-sm);
    opacity: 0;
    pointer-events: none;
    transition:
      opacity var(--motion-fast) var(--ease-out),
      transform var(--motion-fast) var(--ease-out);
  }
  .icon-link[data-tooltip]:hover::after,
  .icon-link[data-tooltip]:focus-visible::after {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
</style>
