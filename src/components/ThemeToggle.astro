---
import { Icon } from "astro-icon/components";

/**
 * ThemeToggle — three-state toggle (system → light → dark) wired to the
 * pre-paint theme script in Base.astro. Persists via localStorage["theme"]
 * (values: "light", "dark", or absent meaning "system"). Re-syncs after
 * Astro view-transition swaps. Storage helpers live in src/lib/theme.ts.
 */
---

<button
  type="button"
  id="theme-toggle"
  data-tooltip="Toggle theme"
  aria-label="Toggle color theme"
  class="theme-toggle tooltip-host inline-flex h-10 w-10 items-center justify-center rounded-md text-muted transition-colors duration-fast ease-out hover:bg-subtle hover:text-fg"
>
  <Icon name="lucide:sun" class="theme-toggle-sun h-5 w-5" aria-hidden="true" />
  <Icon name="lucide:moon" class="theme-toggle-moon h-5 w-5" aria-hidden="true" />
  <Icon name="lucide:monitor" class="theme-toggle-system h-5 w-5" aria-hidden="true" />
  <span class="sr-only" aria-live="polite" data-theme-status>Theme: system</span>
</button>

<style>
  .theme-toggle {
    display: inline-grid;
    place-items: center;
  }
  /* Show exactly one icon based on the current toggle mode. */
  .theme-toggle-sun,
  .theme-toggle-moon,
  .theme-toggle-system {
    grid-area: 1 / 1;
    transition:
      opacity var(--motion-fast) var(--ease-out),
      transform var(--motion-fast) var(--ease-out);
  }
  .theme-toggle[data-mode="system"] .theme-toggle-sun,
  .theme-toggle[data-mode="system"] .theme-toggle-moon {
    opacity: 0;
    transform: scale(0.85);
  }
  .theme-toggle[data-mode="light"] .theme-toggle-moon,
  .theme-toggle[data-mode="light"] .theme-toggle-system {
    opacity: 0;
    transform: scale(0.85);
  }
  .theme-toggle[data-mode="dark"] .theme-toggle-sun,
  .theme-toggle[data-mode="dark"] .theme-toggle-system {
    opacity: 0;
    transform: scale(0.85);
  }
</style>

<script>
  import {
    THEME_ROTATION,
    safeGetTheme,
    safeSetTheme,
    applyTheme,
    type ThemeMode,
  } from "../lib/theme";

  const NEXT_LABEL: Record<ThemeMode, string> = {
    system: "Switch to light theme",
    light: "Switch to dark theme",
    dark: "Switch to system theme",
  };

  const sync = () => {
    const btn = document.getElementById("theme-toggle");
    if (!btn) return;
    const mode = safeGetTheme();
    btn.setAttribute("data-mode", mode);
    btn.setAttribute("aria-label", NEXT_LABEL[mode]);
    btn.setAttribute("data-tooltip", NEXT_LABEL[mode]);
    const status = btn.querySelector<HTMLSpanElement>("[data-theme-status]");
    if (status) status.textContent = `Theme: ${mode}`;
  };

  const onClick = () => {
    const current = safeGetTheme();
    const next = THEME_ROTATION[(THEME_ROTATION.indexOf(current) + 1) % THEME_ROTATION.length];
    safeSetTheme(next);
    applyTheme(next);
    sync();
    document.dispatchEvent(new CustomEvent("theme:change", { detail: { mode: next } }));
  };

  const wire = () => {
    sync();
    const btn = document.getElementById("theme-toggle");
    btn?.addEventListener("click", onClick);
  };

  wire();
  document.addEventListener("astro:after-swap", wire);
</script>
