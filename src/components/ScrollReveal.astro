---
/**
 * ScrollReveal — singleton that wires an IntersectionObserver to all
 * [data-reveal] elements on the page. Drop one instance in the <body>
 * of Base.astro. Re-runs after Astro view-transition swaps.
 *
 * No props. Reduced-motion is handled by the [data-reveal] CSS rule itself.
 */
---

<script>
  const ROOT_MARGIN = "0px 0px -10% 0px";

  const observe = () => {
    const els = document.querySelectorAll<HTMLElement>("[data-reveal]:not(.is-visible)");
    if (els.length === 0) return;

    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            io.unobserve(entry.target);
          }
        }
      },
      { rootMargin: ROOT_MARGIN, threshold: 0.05 },
    );

    for (const el of els) io.observe(el);
  };

  // Reduced-motion users skip the observer entirely; the CSS rule already
  // makes [data-reveal] fully visible by default for them.
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (!prefersReducedMotion) {
    observe();
    document.addEventListener("astro:after-swap", observe);
  }
</script>
