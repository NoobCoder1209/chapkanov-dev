---
import ThemeToggle from "./ThemeToggle.astro";

/**
 * Header — sticky, blurred top bar with name wordmark + nav + theme toggle.
 * Nav highlights the current route via aria-current="page".
 */
const path = Astro.url.pathname.replace(/\/$/, "") || "/";

const links = [
  { href: "/", label: "Home" },
  { href: "/now", label: "Now" },
  { href: "/contact", label: "Contact" },
];

const isCurrent = (href: string) => {
  if (href === "/") return path === "/";
  return path === href || path.startsWith(`${href}/`);
};
---

<a href="#main" class="skip-link">Skip to content</a>

<header
  class="border-border/80 bg-bg/80 supports-[backdrop-filter]:bg-bg/60 sticky top-0 z-50 border-b backdrop-blur"
>
  <div class="container-page flex h-16 items-center justify-between gap-6">
    <a
      href="/"
      class="font-mono text-base font-medium tracking-tight text-fg transition-colors duration-fast ease-out hover:text-accent"
      aria-label="chapkanov.dev — home"
    >
      chapkanov<span class="text-accent">.</span>dev
    </a>

    <nav aria-label="Primary" class="flex items-center gap-1">
      <ul class="flex items-center gap-1">
        {
          links.map((l) => (
            <li>
              <a
                href={l.href}
                aria-current={isCurrent(l.href) ? "page" : undefined}
                class:list={[
                  "block rounded-md px-3 py-2 text-sm transition-colors duration-fast ease-out hover:text-fg",
                  isCurrent(l.href) ? "text-fg" : "text-muted",
                ]}
              >
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
      <span class="mx-2 hidden h-5 w-px bg-border sm:inline-block" aria-hidden="true"></span>
      <ThemeToggle />
    </nav>
  </div>
</header>

<style>
  .skip-link {
    position: absolute;
    left: 1rem;
    top: 0.5rem;
    z-index: 100;
    padding: 0.5rem 0.75rem;
    background: var(--color-accent);
    color: var(--color-accent-fg);
    border-radius: var(--radius-md);
    font-size: var(--fs-sm);
    transform: translateY(-200%);
    transition: transform var(--motion-fast) var(--ease-out);
  }
  .skip-link:focus-visible {
    transform: translateY(0);
  }
</style>
