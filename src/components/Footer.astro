---
import IconLink from "./IconLink.astro";

/**
 * Footer — site-wide footer with social icon links and copyright line.
 */
const year = new Date().getFullYear();

const socials = [
  {
    href: "mailto:alexchapkanov@gmail.com",
    icon: "mail",
    label: "Email",
    external: false,
  },
  {
    href: "https://github.com/NoobCoder1209",
    icon: "github",
    label: "GitHub",
    external: true,
  },
  {
    href: "https://www.linkedin.com/in/aleksandar-chapkanov/",
    icon: "linkedin",
    label: "LinkedIn",
    external: true,
  },
  {
    href: "https://www.upwork.com/freelancers/~014a7c68489b5acdf8",
    icon: "briefcase",
    label: "Upwork",
    external: true,
  },
];
---

<footer class="border-t border-border bg-bg">
  <div
    class="container-page flex flex-col items-center justify-between gap-4 py-8 text-sm text-muted sm:flex-row"
  >
    <p class="text-center sm:text-left">
      © {year} Aleksandar Chapkanov. Built with Astro &amp; Tailwind.
    </p>
    <ul class="flex items-center gap-1">
      {
        socials.map((s) => (
          <li>
            <IconLink href={s.href} icon={s.icon} label={s.label} external={s.external} />
          </li>
        ))
      }
    </ul>
  </div>
</footer>
