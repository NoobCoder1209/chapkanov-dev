---
import "@fontsource-variable/geist";
import "@fontsource-variable/geist-mono";
import "../styles/base.css";
import { ViewTransitions } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
import Seo from "../components/Seo.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  personJsonLd?: boolean;
  canonical?: string | URL;
}

const { title, description, ogImage, personJsonLd, canonical } = Astro.props;
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* FOUC-free pre-paint theme: runs before any content paints. */}
    <script is:inline>
      (() => {
        const KEY = "theme";
        const get = () => {
          try {
            return localStorage.getItem(KEY);
          } catch {
            return null;
          }
        };
        const apply = (theme) => {
          const isDark =
            theme === "dark" ||
            (!theme && window.matchMedia("(prefers-color-scheme: dark)").matches);
          document.documentElement.classList.toggle("dark", isDark);
          document.documentElement.style.colorScheme = isDark ? "dark" : "light";
        };
        apply(get());
        document.addEventListener("astro:after-swap", () => apply(get()));
        window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", () => {
          if (!get()) apply(null);
        });
      })();
    </script>

    <Seo
      title={title}
      description={description}
      ogImage={ogImage}
      personJsonLd={personJsonLd}
      canonical={canonical}
    />

    <ViewTransitions />
  </head>
  <body class="flex min-h-dvh flex-col bg-bg text-fg">
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
    <ScrollReveal />
  </body>
</html>
