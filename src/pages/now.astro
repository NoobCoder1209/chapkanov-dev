---
import Base from "../layouts/Base.astro";
import Reveal from "../components/Reveal.astro";

/* /now — short-form "what I'm doing right now" page. Hand-curated, updated
   occasionally. The list is in-page (not a content collection) until it
   grows past ~10 entries. */
const updates: { date: string; body: string }[] = [
  {
    date: "June 2026",
    body: "Shipping this site. Phase 3 fills the project grid and writes the real bio. The whole build is happening in the open via Claude Code.",
  },
  {
    date: "May 2026",
    body: "Day job: a lot of Go + Helm + ArgoCD on the platform side. After hours: small Claude-powered CLIs and a markdown RAG over my own notes.",
  },
];
---

<Base title="Now — chapkanov.dev" description="What Aleksandar is working on right now.">
  <section class="container-page py-24 md:py-32">
    <Reveal>
      <p class="font-mono text-sm uppercase tracking-widest text-muted">Now</p>
      <h1 class="mt-4 text-4xl font-semibold tracking-tight md:text-5xl">Currently</h1>
      <p class="mt-6 max-w-prose text-lg text-muted">
        Inspired by <a
          href="https://nownownow.com/about"
          target="_blank"
          rel="noopener noreferrer"
          class="text-accent underline decoration-1 underline-offset-4 hover:opacity-80"
          >nownownow.com</a
        >. The honest answer to "what are you doing right now" — not a blog, not a feed, just an
        occasionally-updated list.
      </p>
    </Reveal>

    <Reveal class="mt-12" delayMs={60}>
      <ol class="space-y-8">
        {
          updates.map((u) => (
            <li class="grid gap-2 md:grid-cols-[160px_1fr] md:gap-8">
              <p class="font-mono text-xs uppercase tracking-widest text-muted md:pt-1">{u.date}</p>
              <p class="max-w-prose text-base leading-relaxed text-fg md:text-lg">{u.body}</p>
            </li>
          ))
        }
      </ol>
    </Reveal>
  </section>
</Base>
