---
import Base from "../layouts/Base.astro";
---

<Base title="404 — Page not found · chapkanov.dev" description="That page doesn't exist.">
  <section class="container-page py-32 text-center">
    <p class="font-mono text-sm uppercase tracking-widest text-muted">404</p>
    <h1 class="mt-4 text-4xl font-semibold tracking-tight md:text-5xl">That page doesn't exist.</h1>
    <p class="mt-4 text-base text-muted">
      The URL might be old or mistyped. Either way, no harm done.
    </p>
    <a
      href="/"
      class="mt-10 inline-flex items-center gap-2 rounded-md bg-accent px-5 py-2.5 text-sm font-medium text-accent-fg transition-colors duration-fast ease-out hover:opacity-90"
    >
      Back to home
    </a>
  </section>
</Base>
