---
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import Bio from "../components/Bio.astro";
import ProjectGrid from "../components/ProjectGrid.astro";
import Reveal from "../components/Reveal.astro";
import { getCollection } from "astro:content";

// Pull pinned + non-draft projects. Phase 3 fills the collection.
// Until then, this returns an empty array and ProjectGrid renders its
// empty state — the four-state contract is exercised even pre-content.
const allProjects = await getCollection(
  "projects",
  ({ data }) => data.pinned && data.status !== "draft" && data.status !== "private",
);

// Phase 3 picks one of three drafts; placeholder draft #1 in the meantime.
const bioParagraphs = [
  "I'm an SRE who likes shipping things — Kubernetes operators, AI-powered tools, the occasional production fire.",
  "Most of my day job is platform engineering: making other engineers' lives easier with reliable infrastructure, sane defaults, and the kind of tooling that fades into the background. Outside of that I build with Claude and AI agents — usually little CLIs and integrations that do one thing well.",
  "Based in Sofia. Open to interesting freelance work via Upwork.",
];
---

<Base title="chapkanov.dev — Aleksandar Chapkanov" personJsonLd>
  <Reveal>
    <Hero
      eyebrow="Phase 2b · components"
      title="Hi, I'm Aleksandar. I ship things."
      subhead="SRE by day, building with Claude and AI agents the rest of the time."
      primary={{ href: "#projects", label: "See projects" }}
      secondary={{ href: "/contact", label: "Get in touch" }}
    />
  </Reveal>

  <Reveal delayMs={60}>
    <Bio paragraphs={bioParagraphs} />
  </Reveal>

  <div id="projects">
    <ProjectGrid entries={allProjects} />
  </div>
</Base>
