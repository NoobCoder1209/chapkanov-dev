---
import Base from "../layouts/Base.astro";
import Reveal from "../components/Reveal.astro";
---

<Base title="chapkanov.dev" personJsonLd>
  <section class="container-page py-24 md:py-32">
    <Reveal>
      <p class="font-mono text-sm uppercase tracking-widest text-muted">Phase 2 shell</p>
      <h1 class="mt-4 text-4xl font-semibold tracking-tight md:text-5xl">
        Hi, I'm Aleksandar. I ship things.
      </h1>
      <p class="mt-6 max-w-prose text-lg text-muted">
        SRE by day, building with Claude and AI agents the rest of the time. The real homepage —
        bio, project grid, contact CTA — lands in Phase 3. This page exists to verify the shell:
        header, footer, theme toggle, view transitions, scroll reveal, and SEO metadata.
      </p>
    </Reveal>
    <Reveal class="mt-12" delayMs={80}>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 rounded-md bg-accent px-5 py-2.5 text-sm font-medium text-accent-fg transition-colors duration-fast ease-out hover:opacity-90"
      >
        Probe a navigation (view-transition)
      </a>
    </Reveal>
  </section>
</Base>
